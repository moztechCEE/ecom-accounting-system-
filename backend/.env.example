# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ecommerce_accounting?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Seeded Super Admin Account (set before running prisma db seed)
SUPER_ADMIN_EMAIL="admin@example.com"
SUPER_ADMIN_PASSWORD="ChangeMeToAStrongSecret"
SUPER_ADMIN_NAME="系統管理員"

# Server Configuration
PORT=3000
NODE_ENV="development"

# CORS Configuration
CORS_ORIGIN="http://localhost:3000,http://localhost:3001"

# API Configuration
API_PREFIX="/api/v1"

# Swagger Configuration
SWAGGER_ENABLED=true

# Timezone
TZ="Asia/Taipei"

# Shopify Integration
SHOPIFY_SHOP=""
SHOPIFY_API_VERSION="2024-10"
SHOPIFY_CLIENT_ID=""
SHOPIFY_CLIENT_SECRET=""
SHOPIFY_TOKEN=""
SHOPIFY_WEBHOOK_SECRET=""
SHOPIFY_DEFAULT_ENTITY_ID="tw-entity-001"
SHOPIFY_GATEWAY_FEE_RULES=""
SHOPIFY_SYNC_ENABLED="true"
SHOPIFY_SYNC_LOOKBACK_MINUTES="180"
SHOPIFY_SYNC_JOB_TOKEN=""
RECONCILIATION_SYNC_JOB_TOKEN=""
# Example:
# SHOPIFY_GATEWAY_FEE_RULES='{"綠界科技-信用卡一次付清":{"rate":0.0275},"HiTRUSTpay X LINEpay":{"rate":0.03},"超商貨到付款":{"rate":0}}'

# 1Shop Integration
ONESHOP_API_BASE_URL="https://api.1shop.tw/v1"
ONESHOP_STORES_JSON=""
ONESHOP_APP_ID=""
ONESHOP_SECRET=""
ONESHOP_ACCOUNT=""
ONESHOP_DEFAULT_ENTITY_ID="tw-entity-001"
ONESHOP_STORE_NAME=""
ONESHOP_SYNC_ENABLED="false"
ONESHOP_SYNC_LOOKBACK_DAYS="3"
ONESHOP_MIN_REQUEST_INTERVAL_MS="1100"
CLOUD_RUN_FIXED_EGRESS_IP="104.199.246.28"

# ECPay Shopify Payout Reconciliation
ECPAY_SHOPIFY_API_URL="https://ecpayment.ecpay.com.tw/Cashier/ShopifyQueryTradeMedia"
ECPAY_SHOPIFY_MERCHANT_ID=""
ECPAY_SHOPIFY_HASH_KEY=""
ECPAY_SHOPIFY_HASH_IV=""
ECPAY_SHOPIFY_SYNC_ENABLED="false"
ECPAY_SHOPIFY_SYNC_LOOKBACK_DAYS="14"
ECPAY_SHOPIFY_QUERY_DATE_TYPE="2"

# LINE Pay direct reconciliation
# Do not commit real values. Put these in Secret Manager / Cloud Run env.
LINE_PAY_ACCOUNTS_JSON=""
# Example:
# LINE_PAY_ACCOUNTS_JSON='[{"key":"moztech-shopify","entityId":"tw-entity-001","companyName":"萬博創意科技有限公司","brandName":"墨子科技 MOZTECH","merchantId":"TAP-85030997","channelId":"1657050272","channelSecret":"replace-me","env":"production","sourceChannel":"shopify","ecpayMerchantKey":"shopify-main"}]'
LINE_PAY_PROFILE_KEY="moztech-shopify"
LINE_PAY_ENTITY_ID="tw-entity-001"
LINE_PAY_COMPANY_NAME=""
LINE_PAY_BRAND_NAME=""
LINE_PAY_MERCHANT_ID=""
LINE_PAY_CHANNEL_ID=""
LINE_PAY_CHANNEL_SECRET=""
LINE_PAY_ENV="production"
LINE_PAY_SOURCE_CHANNEL="shopify"
LINE_PAY_ECPAY_MERCHANT_KEY="shopify-main"

GEMINI_API_KEY=
